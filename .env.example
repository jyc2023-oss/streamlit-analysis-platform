APP_NAME=服务器数据分析平台
APP_ENV=development
APP_DATA_DIR=./var
DATA_ROOTS=./sample_data
RESULT_RETENTION_DAYS=30
MAX_SCAN_FILES=10000
MAX_PREVIEW_POINTS=5000
MAX_ANALYSIS_SAMPLES=5000000
SESSION_IDLE_MINUTES=120
MANAGER_URL=
MANAGER_SSO_VERIFY_URL=
MANAGER_SSO_SHARED_SECRET=
WEB_COOKIE_SECURE=false
AUTO_INDEX_STABLE_SECONDS=5
AUTO_INDEX_RECONCILE_SECONDS=300

# 可选：让运行平台的电脑直接索引 SFTP 数据源。密码与私钥口令只写入本机 .env。
SFTP_ENABLED=false
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
SFTP_PRIVATE_KEY_PATH=
SFTP_PRIVATE_KEY_PASSPHRASE=
SFTP_REMOTE_ROOT=/data/usershare/test-manager/datas
SFTP_SYNC_SECONDS=30
SFTP_CACHE_TTL_HOURS=24
SFTP_CACHE_MAX_GB=20
SFTP_ALLOW_UNKNOWN_HOST_KEY=false

# 首次启动时可用脚本创建管理员。不要在正式 .env 中保留示例密码。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
